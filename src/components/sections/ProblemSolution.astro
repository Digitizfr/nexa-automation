---
import SectionHeading from "../ui/SectionHeading.astro";

interface PainPoint {
  icon: string;
  problem: string;
  solution: string;
}

interface Props {
  painPoints: PainPoint[];
}

const { painPoints } = Astro.props;

const icons: Record<string, string> = {
  clock: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  error: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  chart: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />`,
};
---

<section class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      badge="Pourquoi automatiser ?"
      title="Vos défis, <span class='gradient-text'>nos solutions</span>"
      subtitle="Les tâches répétitives freinent votre croissance. NEXA les transforme en avantage compétitif."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {painPoints.map((point) => (
        <div class="group relative">
          <!-- Problem -->
          <div class="bg-mystique/50 rounded-2xl p-8 h-full border border-transparent transition-all duration-500 group-hover:border-emeraude/20 group-hover:bg-white group-hover:shadow-xl">
            <div class="w-12 h-12 rounded-xl bg-emeraude/10 flex items-center justify-center mb-6 group-hover:bg-emeraude/20 transition-colors">
              <svg class="w-6 h-6 text-emeraude" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={icons[point.icon] || icons.clock} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-anchor mb-3">{point.problem}</h3>
            <p class="text-anchor/60 leading-relaxed">{point.solution}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
