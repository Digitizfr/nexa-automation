---
import Button from "../ui/Button.astro";
import SectionHeading from "../ui/SectionHeading.astro";

interface Service {
  icon: string;
  title: string;
  description: string;
  tools: string[];
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

const iconPaths: Record<string, string> = {
  workflow: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />`,
  api: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" />`,
  brain: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />`,
  search: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />`,
};
---

<section class="py-20 sm:py-28 bg-mystique/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      badge="Nos expertises"
      title="Des solutions sur mesure pour <span class='gradient-text'>chaque besoin</span>"
      subtitle="De l'automatisation simple aux intégrations complexes, nous couvrons l'ensemble de vos besoins."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map((service, index) => (
        <div class="group bg-white rounded-2xl p-8 border border-mystique/50 hover:border-emeraude/30 hover:shadow-xl transition-all duration-300">
          <div class="flex items-start gap-6">
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={iconPaths[service.icon] || iconPaths.workflow} />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-anchor mb-3 group-hover:text-emeraude transition-colors">
                {service.title}
              </h3>
              <p class="text-anchor/60 leading-relaxed mb-4">{service.description}</p>
              <div class="flex flex-wrap gap-2">
                {service.tools.map((tool) => (
                  <span class="px-3 py-1 text-xs font-medium bg-mystique text-sapphire rounded-full">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <Button href="/services" variant="outline" size="lg">
        Voir tous nos services
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </div>
</section>
