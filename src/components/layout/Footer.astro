---
import { Image } from "astro:assets";
import logoWhite from "../../assets/logo-white.png";

interface FooterLink {
  label: string;
  href: string;
}

const services: FooterLink[] = [
  { label: "Automatisation de workflows", href: "/services#workflows" },
  { label: "Intégration d'APIs", href: "/services#api" },
  { label: "Solutions IA", href: "/services#ia" },
  { label: "Conseil & Audit", href: "/services#audit" },
];

const entreprise: FooterLink[] = [
  { label: "À propos", href: "/a-propos" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const currentYear = new Date().getFullYear();
---

<footer class="gradient-bg-dark text-white/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <Image
            src={logoWhite}
            alt="NEXA Automation"
            width={160}
            height={44}
            class="h-10 w-auto"
          />
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          L'Intelligence en Action. Nous automatisons vos processus métiers pour vous faire gagner du temps et de l'efficacité.
        </p>
        <div class="flex gap-4">
          <a href="#" class="text-white/40 hover:text-arctique transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="text-white/40 hover:text-arctique transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-heading text-lg mb-6">Services</h3>
        <ul class="space-y-3">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/60 hover:text-arctique transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Entreprise -->
      <div>
        <h3 class="text-white font-heading text-lg mb-6">Entreprise</h3>
        <ul class="space-y-3">
          {entreprise.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/60 hover:text-arctique transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-heading text-lg mb-6">Contact</h3>
        <ul class="space-y-3 text-sm text-white/60">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-arctique shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:contact@nexa-automation.fr" class="hover:text-arctique transition-colors">
              contact@nexa-automation.fr
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-arctique shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>France</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-white/40">
        &copy; {currentYear} NEXA Automation. Tous droits réservés.
      </p>
      <div class="flex gap-6 text-sm text-white/40">
        <a href="#" class="hover:text-arctique transition-colors">Mentions légales</a>
        <a href="#" class="hover:text-arctique transition-colors">Politique de confidentialité</a>
      </div>
    </div>
  </div>
</footer>
