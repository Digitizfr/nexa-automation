---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import CTA from "../../components/sections/CTA.astro";
import { getCollection } from "astro:content";

const caseStudies = (await getCollection("case-studies"))
  .filter((study) => !study.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Portfolio — NEXA Automation"
  description="Découvrez nos réalisations en automatisation. Cas clients concrets avec résultats mesurables dans divers secteurs d'activité."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-mystique via-white to-arctique/10 py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 rounded-full bg-emeraude/10 text-emeraude text-sm font-medium mb-6">
        Portfolio
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading mb-6">
        Nos <span class="gradient-text">réalisations</span>
      </h1>
      <p class="text-lg sm:text-xl text-anchor/60 max-w-2xl mx-auto">
        Des cas concrets d'automatisation avec des résultats mesurables pour des entreprises comme la vôtre.
      </p>
    </div>
  </section>

  <!-- Cases Grid -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {caseStudies.map((study) => (
          <a href={`/portfolio/${study.slug}`} class="group block">
            <article class="bg-white rounded-2xl border border-mystique/50 overflow-hidden hover:border-emeraude/30 hover:shadow-xl transition-all duration-300 h-full flex flex-col">
              <!-- Color bar -->
              <div class="h-2 gradient-bg"></div>

              <div class="p-8 flex flex-col flex-1">
                <div class="flex flex-wrap gap-2 mb-4">
                  <Badge variant="accent">{study.data.sector}</Badge>
                </div>

                <h3 class="text-xl font-semibold text-anchor mb-3 group-hover:text-emeraude transition-colors">
                  {study.data.title}
                </h3>
                <p class="text-anchor/60 text-sm leading-relaxed mb-6 flex-1">
                  {study.data.description}
                </p>

                <!-- Results preview -->
                <div class="space-y-2 mb-6">
                  {study.data.results.slice(0, 2).map((result) => (
                    <div class="flex items-start gap-2 text-sm">
                      <svg class="w-4 h-4 text-emeraude shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-anchor/70">{result}</span>
                    </div>
                  ))}
                </div>

                <!-- Tools -->
                <div class="flex flex-wrap gap-1.5 pt-4 border-t border-mystique/50">
                  {study.data.tools.map((tool) => (
                    <span class="px-2 py-0.5 text-xs bg-mystique text-sapphire rounded-full">
                      {tool}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Votre projet pourrait être le prochain"
    subtitle="Discutons de vos besoins en automatisation et créons ensemble votre success story."
    ctaLabel="Démarrer un projet"
    ctaHref="/contact"
  />
</BaseLayout>
