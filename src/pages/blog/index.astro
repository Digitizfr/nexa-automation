---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import Badge from "../../components/ui/Badge.astro";
import CTA from "../../components/sections/CTA.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/helpers";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — NEXA Automation"
  description="Articles et guides sur l'automatisation des processus métiers, les outils no-code et l'intelligence artificielle appliquée aux PME."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-mystique via-white to-arctique/10 py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 rounded-full bg-emeraude/10 text-emeraude text-sm font-medium mb-6">
        Blog
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading mb-6">
        Actualités & <span class="gradient-text">ressources</span>
      </h1>
      <p class="text-lg sm:text-xl text-anchor/60 max-w-2xl mx-auto">
        Guides pratiques, comparatifs d'outils et retours d'expérience sur l'automatisation et l'IA.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-anchor/50 text-lg">Aucun article pour le moment. Revenez bientôt !</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block">
              <article class="bg-white rounded-2xl border border-mystique/50 overflow-hidden hover:border-emeraude/30 hover:shadow-xl transition-all duration-300 h-full flex flex-col">
                <div class="h-2 gradient-bg"></div>
                <div class="p-8 flex flex-col flex-1">
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <Badge variant="default">{tag}</Badge>
                    ))}
                  </div>
                  <h3 class="text-xl font-semibold text-anchor mb-3 group-hover:text-emeraude transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-anchor/60 text-sm leading-relaxed mb-6 flex-1">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between pt-4 border-t border-mystique/50 text-sm text-anchor/40">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span class="text-emeraude group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                      Lire
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </span>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CTA
    title="Besoin d'aide pour automatiser ?"
    subtitle="Nos experts sont là pour vous accompagner dans votre transformation digitale."
    ctaLabel="Nous contacter"
    ctaHref="/contact"
  />
</BaseLayout>
